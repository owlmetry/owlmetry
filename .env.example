DATABASE_URL=postgresql://localhost:5432/owlmetry
JWT_SECRET=dev-secret-change-me
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000
MAX_DATABASE_SIZE_GB=0
RESEND_API_KEY=
EMAIL_FROM=noreply@owlmetry.com
COOKIE_DOMAIN=

# Event attachments (SDK file uploads for debugging failed events).
# Directory where file bytes are stored. Defaults to ./data/attachments in dev
# and /opt/owlmetry-attachments in prod. Exclude from pg_dump backups.
OWLMETRY_ATTACHMENTS_PATH=
# HMAC secret for signed download URLs. REQUIRED in production — server will refuse
# to start without it. Generate with `openssl rand -hex 32`. Must NOT equal JWT_SECRET.
# In dev this falls back to JWT_SECRET for convenience.
OWLMETRY_ATTACHMENTS_SIGNING_SECRET=
# If nginx is configured with an `internal` location mapped to OWLMETRY_ATTACHMENTS_PATH,
# set this to that URI prefix (e.g. "/_attachments/") and the server will send
# X-Accel-Redirect instead of streaming bytes through Node. Leave empty in dev.
OWLMETRY_ATTACHMENTS_INTERNAL_URI=

# iOS push (APNs). Optional — without these, push deliveries are silently
# skipped and email + in-app keep working. Token-based auth via a .p8 key
# downloaded from Apple Developer (Keys → Apple Push Notifications service).
# Single Apple Developer account → single set of keys.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.Owlmetry
# Sandbox vs production routing is per-device — the iOS client tells the server
# which environment its token belongs to at registration time, no server flag.
# PEM contents of the .p8 key. Wrap in double quotes — dotenv 16 preserves
# real newlines inside quoted values, so paste the file contents verbatim:
# APNS_KEY_P8="-----BEGIN PRIVATE KEY-----
# MIGTAgEAMB...
# -----END PRIVATE KEY-----"
APNS_KEY_P8=
