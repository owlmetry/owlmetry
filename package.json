{
  "name": "owlmetry",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @owlmetry/server dev",
    "dev:web": "pnpm --filter @owlmetry/web dev",
    "dev:cli": "pnpm --filter ./apps/cli dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @owlmetry/db generate",
    "db:migrate": "pnpm --filter @owlmetry/db migrate",
    "dev:seed": "pnpm --filter @owlmetry/db dev:seed",
    "dev:seed-events": "pnpm --filter @owlmetry/db dev:seed-events",
    "dev:seed-issues": "pnpm --filter @owlmetry/db dev:seed-issues",
    "dev:unsafe-reset": "pnpm --filter @owlmetry/db dev:unsafe-reset",
    "db:cleanup": "pnpm --filter @owlmetry/db cleanup",
    "db:cleanup-stranded-anons": "pnpm --filter @owlmetry/db cleanup-stranded-anons",
    "test": "pnpm -r test && pnpm test:cli",
    "test:cli": "bash scripts/test-cli.sh",
    "test:coverage": "pnpm --filter @owlmetry/server exec vitest run --coverage",
    "publish:cli": "cd apps/cli && npm version patch --no-git-tag-version && cd ../.. && pnpm build && cd apps/cli && npm publish --access public",
    "prod:jobs": "bash scripts/prod-jobs.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ],
    "overrides": {
      "drizzle-orm": "0.39.3"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
