{
  "name": "@owlmetry/db",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/migrate.ts",
    "dev:seed": "tsx src/seed.ts",
    "dev:seed-events": "tsx src/seed-events.ts",
    "dev:unsafe-reset": "tsx src/clear.ts",
    "cleanup": "tsx src/cleanup.ts"
  },
  "dependencies": {
    "@owlmetry/shared": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
