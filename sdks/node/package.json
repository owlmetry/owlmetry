{
  "name": "@owlmetry/node",
  "version": "0.1.9",
  "description": "OwlMetry Node.js Server SDK",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jasonvdb/owlmetry.git",
    "directory": "sdks/node"
  },
  "homepage": "https://owlmetry.com",
  "bugs": "https://github.com/Jasonvdb/owlmetry/issues",
  "keywords": [
    "owlmetry",
    "analytics",
    "metrics",
    "funnels",
    "logging",
    "observability",
    "node",
    "sdk"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
